# =============================================================================
# Variáveis de Ambiente para as Edge Functions (Supabase Secrets)
#
# Para configurar, execute na raiz do projeto:
#   supabase secrets set NOME_VARIAVEL=valor
#
# Ou via painel: Supabase Dashboard → Edge Functions → Manage Secrets
# =============================================================================

# --- Evolution API ---
# URL base da sua instância Evolution API
EVOLUTION_API_URL=https://skinnysalmon-evolution.cloudfy.cloud

# API Key da Evolution (encontra em Settings > API Keys na Evolution)
EVOLUTION_API_KEY=62CAF54F-3E1A-4607-BDAE-1FE22A991473

# Nome da instância WhatsApp conectada na Evolution
EVOLUTION_INSTANCE=org-prestes

# --- Google Gemini ---
# Chave para transcrição de áudio (Workflow 1) e geração de sugestões (Workflow 2)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# --- Supabase (injetadas automaticamente nas Edge Functions) ---
# NÃO precisam ser configuradas manualmente:
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
